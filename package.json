{
  "name": "datum.net",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:astro": "astro dev --host --typecheck",
    "build:astro": "astro check --skip-playwright && astro build",
    "dev": "npm run dev:astro",
    "build": "npm run build:astro",
    "build:cache": "tsx scripts/warmup-cache.ts",
    "start": "node ./server.mjs",
    "start:original": "node ./dist/server/entry.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "npx markdownlint-cli \"src/content/**/*.{md,mdx}\"",
    "lint:md:fix": "npx markdownlint-cli \"src/content/**/*.{md,mdx}\" --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,astro,md,mdx,json,css,scss}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,astro,md,mdx,json,css,scss}\"",
    "prepare": "husky",
    "typecheck": "astro check",
    "precommit": "npm run typecheck && npm run lint && npm run lint:md:fix && npm run format && npm run format:check",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.11",
    "@astrojs/alpinejs": "^0.5.0",
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/node": "^10.0.4",
    "@astrojs/rss": "^4.0.18",
    "@kubernetes/client-node": "^1.4.0",
    "@lucide/astro": "^1.8.0",
    "@nanostores/persistent": "^1.3.3",
    "@playform/compress": "^0.2.3",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "alpinejs": "^3.15.11",
    "astro": "^6.1.5",
    "astro-breadcrumbs": "^3.4.0",
    "astro-compressor": "^1.3.0",
    "astro-mermaid": "^2.0.1",
    "astro-robots-txt": "^1.0.0",
    "astro-seo": "^1.1.0",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "jwt-decode": "^4.0.0",
    "lenis": "^1.3.21",
    "marked": "^18.0.0",
    "mermaid": "^11.14.0",
    "nanostores": "^1.2.0",
    "octokit": "^5.0.5",
    "openid-client": "^6.8.2",
    "postgres": "^3.4.9",
    "rehype-expressive-code": "^0.41.7",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sirv": "^3.0.2",
    "slugify": "^1.6.9",
    "tailwindcss": "^4.2.2",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.7",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/alpinejs": "^3.13.11",
    "@types/alpinejs__collapse": "^3.13.4",
    "@types/hast": "^3.0.4",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shx": "^0.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "vite": "^7.3.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "4.60.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,mdx}": [
      "npx markdownlint-cli --fix"
    ],
    "*.{json,css,scss}": [
      "prettier --write"
    ]
  }
}
