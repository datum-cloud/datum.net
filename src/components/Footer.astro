---
// src/components/Footer.astro
import { Image } from 'astro:assets';
import navigation from '@data/navigation.json';
import type { NavData, NavFooterCard, NavItem } from '@/src/types/navigation';
import type { FooterProps } from '@/src/types/common';
import ImageFooter from '@assets/images/footer-illustration.png';
import Button from '@components/Button.astro';
import Icon from '@components/Icon.astro';
import ImageTwoMen from '@assets/images/two-person-talking.png';
import NewsletterModal from '@components/forms/NewsletterModal.astro';
import FooterAiAgents from '@components/FooterAiAgents.astro';

const {
  showCTA = true,
  showBackground = true,
  showIllustration = false,
  showSignup = true,
  plainIllustration = false,
} = Astro.props as FooterProps;

const navData = navigation as NavData;
const [platformSection, resourcesSection, companySection] = navData.footer;
---

<footer
  id="footer"
  class:list={['footer relative bg-white text-white', !showBackground && 'bg-midnight-fjord']}
>
  {
    showCTA && (
      <div class="footer-prefooter px-4 sm:px-7">
        <div class="max-width-nav relative">
          <span class="section-line section-line--left section-line--top" />
          <span class="section-eyebrow section-eyebrow--midnight-fjord section-eyebrow--left-top">
            Get started
          </span>

          <div class="footer-prefooter-grid" aria-hidden="true">
            <svg
              class="line-draw"
              viewBox="0 0 255 282"
              fill="none"
              preserveAspectRatio="xMaxYMin slice"
            >
              <rect data-line-draw x="135" y="81.5" width="80" height="80" fill="#E6F59F" />
              <rect data-line-draw x="16" y="121.5" width="40" height="40" fill="#E6F59F" />
              <rect data-line-draw x="136" y="241.5" width="40" height="40" fill="#E6F59F" />
              <path data-line-draw pathLength="1" d="M215 0.5L215 120.5" stroke="#C3C6C9" />
              <path data-line-draw pathLength="1" d="M136 41.5L136 280.5" stroke="#C3C6C9" />
              <path data-line-draw pathLength="1" d="M56 121.5L56 160.5" stroke="#C3C6C9" />
              <path data-line-draw pathLength="1" d="M96 240.5H176" stroke="#C3C6C9" />
              <path data-line-draw pathLength="1" d="M0 160.5L176 160.5" stroke="#C3C6C9" />
              <path data-line-draw pathLength="1" d="M96 80.5L255 80.5" stroke="#C3C6C9" />
            </svg>
          </div>
          <div class="max-width-nopad flex flex-col items-center gap-5.5 pt-14 text-center md:gap-10 md:pt-24 lg:pt-28 xl:pt-32 2xl:pt-40">
            <h2 class="section--title">
              <span class="text-pine-forge---links">Start here,</span> go anywhere
            </h2>
            <p class="datum-text-xl max-w-5xl text-pretty opacity-80">
              Own more of your stack, reduce latency across regions, and connect privately with
              customers.
            </p>
            <div class="flex items-center justify-center gap-4">
              <Button
                class="btn btn--midnight-fjord btn--glow-aurora"
                text="Start for free"
                icon={{ name: 'arrow-right', size: 'md' }}
                iconPosition="right"
                iconClass="stroke-1.5"
                target="_blank"
                href="https://auth.datum.net/ui/v2/login/register"
                data-rybbit-event="Pre-footer: Start for free"
              />
              <Button
                class="btn btn--alpha"
                text="Request a demo"
                href="/demo"
                data-rybbit-event="Pre-footer: Request a demo"
              />
            </div>
          </div>
        </div>
      </div>
    )
  }

  {
    showBackground && (
      <div
        class:list={[
          'footer-illustration-container',
          !showCTA && !plainIllustration && 'bg-glacier-mist-700 pt-30',
          plainIllustration && 'footer-illustration-container--plain',
        ]}
      >
        <div class="relative w-full">
          <Image
            src={ImageFooter}
            layout="constrained"
            alt="Footer illustration"
            class="relative mr-auto size-auto w-full -translate-y-3 object-cover"
          />
        </div>
      </div>
    )
  }

  {
    showIllustration && (
      <div class="3xl:right-55 2-5xl:right-50 absolute -top-[94px] right-15 z-10 hidden lg:right-25 lg:inline-block">
        <Image
          src={ImageTwoMen}
          alt="Two Person Talking"
          class="relative h-auto w-[79px]"
          data-scroll-effect="parallax"
          data-scroll-speed="0.1"
          data-scroll-direction="down"
          data-viewport-offset="-500"
          data-max-movement="20"
        />
      </div>
    )
  }

  <div class="bg-midnight-fjord relative z-20">
    <div class="footer-main">
      <div class="footer-grid">
        <div class="footer-cards">
          {
            navData.footerCards.map((card: NavFooterCard) => (
              <a
                href={card.href}
                class="footer-card"
                target={card.isExternal ? '_blank' : undefined}
                rel={card.isExternal ? 'noopener noreferrer' : undefined}
                data-astro-prefetch={card.isExternal ? undefined : 'hover'}
              >
                <Icon name={card.icon} size="lg" class="footer-card-icon" />
                <span class="footer-card-content">
                  <span class="footer-card-title">{card.title}</span>
                  <span class="footer-card-description">{card.description}</span>
                </span>
              </a>
            ))
          }
        </div>

        <div class="footer-nav-container" role="navigation">
          {
            platformSection && (
              <div class="footer-nav-section">
                <p class="footer-nav-header">{platformSection.title}</p>
                <ul class="footer-nav-list">
                  {platformSection.items.map((item: NavItem) => (
                    <li>
                      <a
                        href={item.href}
                        class="footer-nav-link"
                        target={item.isExternal ? '_blank' : undefined}
                        rel={item.isExternal ? 'noopener noreferrer' : undefined}
                        data-astro-prefetch="hover"
                        title={item.text}
                        tabindex="0"
                      >
                        {item.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )
          }

          {
            resourcesSection && (
              <div class="footer-nav-section footer-nav-section--stacked">
                <div class="footer-nav-group">
                  <p class="footer-nav-header">{resourcesSection.title}</p>
                  <ul class="footer-nav-list">
                    {resourcesSection.items.map((item: NavItem) => (
                      <li>
                        <a
                          href={item.href}
                          class="footer-nav-link"
                          target={item.isExternal ? '_blank' : undefined}
                          rel={item.isExternal ? 'noopener noreferrer' : undefined}
                          data-astro-prefetch="hover"
                          title={item.text}
                          tabindex="0"
                        >
                          {item.text}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="footer-nav-group">
                  <p class="footer-nav-header">Status</p>
                  <div
                    id="hyperping-badge"
                    class="footer-status-badge datum-docs-sidebar-headings text-glacier-mist-700 [&>div]:bg-logo-object/15 min-w-[140px] normal-case [&>div]:rounded-md [&>div]:px-2 [&>div]:py-1"
                  />
                </div>
              </div>
            )
          }

          {
            companySection && (
              <div class="footer-nav-section">
                <p class="footer-nav-header">{companySection.title}</p>
                <ul class="footer-nav-list">
                  {companySection.items.map((item: NavItem) => (
                    <li>
                      <a
                        href={item.href}
                        class="footer-nav-link"
                        target={item.isExternal ? '_blank' : undefined}
                        rel={item.isExternal ? 'noopener noreferrer' : undefined}
                        data-astro-prefetch="hover"
                        title={item.text}
                        tabindex="0"
                      >
                        {item.text}
                      </a>
                      {item.label && <span class="nav-label">{item.label}</span>}
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
        </div>
      </div>

      <FooterAiAgents social={navData.social} />
    </div>
  </div>

  {
    showSignup && (
      <div
        id="footer-signup"
        class="bg-blush-quartz text-midnight-fjord py-9 md:py-10 lg:py-12 xl:py-20"
      >
        <div class="max-width flex w-full max-w-190 grow flex-col items-center gap-4 md:w-auto md:max-w-none md:gap-11 lg:gap-13.5">
          <h3 class="datum-text-7xl mb-0">Let's stay connected, shall we?</h3>

          <div data-newsletter-trigger>
            <Button
              class="btn btn--alpha"
              text="Get our monthly email"
              icon={{ name: 'arrow-right', size: 'md' }}
              iconPosition="right"
              iconClass="stroke-1.5"
              href="#"
            />
          </div>
        </div>
      </div>
    )
  }

  <NewsletterModal />
</footer>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('[data-newsletter-trigger]');
    if (!triggers.length) return;
    const openNewsletterModal = () => {
      if (window.NEWSLETTER_MODAL_OPEN_EVENT) {
        document.dispatchEvent(new CustomEvent(window.NEWSLETTER_MODAL_OPEN_EVENT));
      }
    };
    triggers.forEach((trigger) => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        const label = trigger.getAttribute('data-newsletter-rybbit') || 'Footer: Newsletter Signup';
        if (window.rybbit) window.rybbit.event(label);
        openNewsletterModal();
      });
    });
  });
</script>
