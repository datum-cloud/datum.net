---
// src/components/FooterAiAgents.astro
import Icon from '@components/Icon.astro';
import Button from '@components/Button.astro';
import MarkdownLightbox from '@components/MarkdownLightbox.astro';
import claudeSvg from '@assets/icons/ai/claude.svg?raw';
import chatgptSvg from '@assets/icons/ai/chatgpt.svg?raw';
import geminiSvg from '@assets/icons/ai/gemini.svg?raw';
import perplexitySvg from '@assets/icons/ai/perplexity.svg?raw';
import promptRaw from '@data/ai-prompt.md?raw';
import { resolveMarkdownUrl } from '@utils/markdownExport';
import type { NavItem } from '@/src/types/navigation';

interface FooterAiAgentsProps {
  social: NavItem[];
}

const { social } = Astro.props as FooterAiAgentsProps;

const encodedPrompt = encodeURIComponent(promptRaw);
const markdownUrl = await resolveMarkdownUrl(Astro.url.pathname);

const aiTools = [
  {
    name: 'Claude',
    icon: claudeSvg,
    href: `https://claude.ai/new?q=${encodedPrompt}`,
  },
  {
    name: 'ChatGPT',
    icon: chatgptSvg,
    href: `https://chatgpt.com/?q=${encodedPrompt}`,
  },
  {
    name: 'Gemini',
    icon: geminiSvg,
    href: `https://aistudio.google.com/prompts/new_chat?prompt=${encodedPrompt}`,
  },
  {
    name: 'Perplexity',
    icon: perplexitySvg,
    href: `https://www.perplexity.ai/search?q=${encodedPrompt}`,
  },
];
---

<div class="footer-bottom">
  <div class="footer-bottom-row">
    <div class="footer-bottom-ai">
      <p class="footer-bottom-ai-label">Create a summary of Datum</p>
      <div class="footer-bottom-ai-tools">
        {
          aiTools.map((tool) => (
            <a
              href={tool.href}
              class="footer-ai-tool"
              target="_blank"
              rel="noopener noreferrer"
              title={`Open ${tool.name} with a summary prompt`}
            >
              <span class="footer-ai-tool-icon" set:html={tool.icon} />
              <span>{tool.name}</span>
            </a>
          ))
        }
      </div>
    </div>

    <div class="footer-bottom-links">
      {
        markdownUrl && (
          <a
            href={markdownUrl}
            data-markdown-trigger
            data-md-title={`cat ${markdownUrl}`}
            class="markdown-lightbox-trigger"
            aria-label="Read this page as Markdown"
          >
            <span class="markdown-lightbox-trigger__label">
              Read as <strong>Markdown</strong>
            </span>
            <Icon name="file-text" size="md" class="markdown-lightbox-trigger__icon" />
          </a>
        )
      }
      <a
        href="https://agents.datum.net"
        class="footer-bottom-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="footer-bottom-link-text">
          Agents, use <strong>Agents.Datum.net</strong>
        </span>
        <Icon name="external-link" size="md" class="footer-bottom-link-icon stroke-1.5" />
      </a>
    </div>
  </div>

  <div class="footer-bottom-meta">
    <p class="footer-copyright">&copy; {new Date().getFullYear()} Datum Technology Inc.</p>
    <div class="footer-social">
      {
        social.map((item) => (
          <Button
            class="btn btn--clean footer-social-link"
            icon={{ name: item.icon, size: 'md' }}
            iconPosition="left"
            iconClass="stroke-1.5"
            target={item.isExternal ? '_blank' : '_self'}
            href={item.href}
            text=""
            title={item.text}
          />
        ))
      }
    </div>
  </div>
</div>

<MarkdownLightbox />
