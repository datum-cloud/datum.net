---
import { Image } from 'astro:assets';
import { marked } from 'marked';

import Nav from '@components/Nav.astro';
import Icon from '@components/Icon.astro';
import Announcement from '@components/Announcement.astro';
import SectionLine from '@components/SectionLine.astro';

import type { HeroProps } from '@/src/types/common';

const {
  iconName = '',
  title = '',
  titleTag = 'h1',
  subtitle = '',
  description = '',
  class: className,
  imagePath,
  hideContent = false,
  hideHero = false,
  showSectionLines = false,
} = Astro.props as HeroProps;

const TitleTag = titleTag;
---

<header class:list={['hero--main', className]}>
  <Announcement />
  <Nav />

  {
    !hideHero && (
      <div class="section--block--x-pad section--block">
        <div class="hero--content-container spacing-pad">
          {Astro.slots.has('before-content') && (
            <div class="hero--before-content">
              <slot name="before-content" />
            </div>
          )}

          {!hideContent && (
            <div class="hero--main-content">
              {/* Hero Main Content */}
              {(title || description) && (
                <div class="hero--main-content-inner" role="banner">
                  {(iconName && iconName !== '') || (subtitle && subtitle !== '') ? (
                    <div class="hero--main-content-icon">
                      {iconName && iconName !== '' && (
                        <div class="hero--main-content-icon-inner">
                          <Icon name={iconName} size="md" />
                        </div>
                      )}
                      {subtitle && subtitle !== '' && <span set:html={subtitle} />}
                    </div>
                  ) : null}

                  {title && (
                    <TitleTag
                      class="hero--main-content-title"
                      set:html={marked.parseInline(title)}
                    />
                  )}
                  {description && (
                    <p
                      class="hero--main-content-description"
                      set:html={marked.parseInline(description)}
                    />
                  )}
                </div>
              )}

              {imagePath && (
                <div class="hero--main-content-image">
                  <Image
                    src={imagePath}
                    alt={title}
                    data-scroll-effect="parallax"
                    data-scroll-speed="0.1"
                    data-scroll-direction="down"
                    data-viewport-offset="0"
                    data-max-movement="50"
                  />
                </div>
              )}
            </div>
          )}

          {showSectionLines && <SectionLine left right top bottom />}
        </div>
      </div>
    )
  }
</header>
