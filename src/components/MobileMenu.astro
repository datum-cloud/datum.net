---
// src/components/MobileMenu.astro
import type { NavData } from '@/src/types/navigation';
import Icon from '@components/Icon.astro';
import Logo from '@v1/assets/svgs/datum-logo-h.svg';
import DiscordIcon from '@v1/assets/icons/discord.svg';
import GithubIcon from '@v1/assets/icons/github.svg';
import navigation from '@data/navigation.json';

// Type-safe navigation data
const navData = navigation as NavData;
const mainNav = navData.main;
---

<div
  class="mobile-menu-container"
  x-data="{
    isOpen: false,
    toggleMenu() {
      this.isOpen = !this.isOpen;
      if (this.isOpen) {
        document.body.style.overflow = 'hidden';
        document.body.classList.add('mobile-menu-open');
      } else {
        this._closeWithDelay();
      }
    },
    closeMenu() {
      this.isOpen = false;
      this._closeWithDelay();
    },
    _closeWithDelay() {
      setTimeout(() => {
        if (!this.isOpen) {
          document.body.style.overflow = '';
          document.body.classList.remove('mobile-menu-open');
        }
      }, 300);
    }
  }"
  x-init="
    // Close menu on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closeMenu();
      }
    });

    // Close menu on window resize
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024 && isOpen) {
        closeMenu();
      }
    });
  "
>
  <!-- Mobile Menu Button -->
  <button
    x-on:click="toggleMenu()"
    class="mobile-menu-button"
    aria-label="Toggle mobile menu"
    x-bind:aria-expanded="isOpen"
  >
    <svg
      class="mobile-menu-icon"
      x-bind:class="{ 'mobile-menu-icon--open': isOpen }"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 30 30"
      aria-hidden="true"
    >
      <path class="burger-top" d="M4 7h22" stroke-width="2.5" stroke-linecap="round"></path>
      <path class="burger-mid" d="M4 15h22" stroke-width="2.5" stroke-linecap="round"></path>
      <path class="burger-bot" d="M4 23h22" stroke-width="2.5" stroke-linecap="round"></path>
    </svg>
  </button>

  <!-- Overlay -->
  <div
    x-show="isOpen"
    x-cloak
    style="display: none"
    x-transition:enter="transition-opacity ease-linear duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition-opacity ease-linear duration-300"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    x-on:click="closeMenu()"
    class="mobile-menu-overlay"
  >
  </div>

  <!-- Mobile Menu Panel -->
  <div
    x-show="isOpen"
    x-cloak
    style="display: none"
    x-transition:enter="transition ease-in-out duration-300 transform"
    x-transition:enter-start="-translate-x-full"
    x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in-out duration-300 transform"
    x-transition:leave-start="translate-x-0"
    x-transition:leave-end="-translate-x-full"
    class="mobile-menu"
  >
    <!-- Logo -->
    <a href="/" class="mobile-menu-logo" x-on:click="closeMenu()">
      <Logo />
    </a>

    <!-- Nav Links -->
    <div class="mobile-menu-content">
      <ul class="mobile-menu-list">
        {
          mainNav.map((item) =>
            item.children ? (
              <li class="mobile-menu-item" x-data="{ open: false }">
                <button
                  class="mobile-menu-link"
                  x-on:click="open = !open"
                  x-bind:aria-expanded="open"
                  type="button"
                >
                  <span>{item.text}</span>
                  <span class="mobile-menu-link-icon" x-bind:class="{ 'rotate-180': open }">
                    <Icon name="chevron-down" size="md" />
                  </span>
                </button>

                <div class="mobile-dropdown-content" x-show="open" x-collapse>
                  {item.children.map((section) => (
                    <div class="mobile-dropdown-section">
                      {'title' in section && section.title && (
                        <h3 class="mobile-dropdown-title">{section.title}</h3>
                      )}
                      <ul class="mobile-dropdown-items">
                        {section.items?.map((subItem) => (
                          <li class="mobile-dropdown-item">
                            <a
                              href={subItem.href}
                              class="mobile-dropdown-link"
                              target={subItem.isExternal ? '_blank' : undefined}
                              rel={subItem.isExternal ? 'noopener noreferrer' : undefined}
                              x-on:click="closeMenu()"
                            >
                              <span>{subItem.text}</span>
                              {subItem.isExternal && (
                                <Icon
                                  name="external-link"
                                  size="sm"
                                  class="nav-dropdown-external-icon"
                                />
                              )}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </li>
            ) : (
              <li class="mobile-menu-item">
                <a
                  href={item.href}
                  class="mobile-menu-link"
                  x-on:click="closeMenu()"
                  data-astro-prefetch="load"
                >
                  <span>{item.text}</span>
                  <span class="mobile-menu-link-icon">
                    <Icon name="arrow-right" size="md" />
                  </span>
                </a>
              </li>
            )
          )
        }
      </ul>
    </div>

    <!-- Footer: CTAs + Social -->
    <div class="mobile-menu-footer">
      <div class="mobile-menu-ctas">
        <a href="https://cloud.datum.net/" class="mobile-cta-secondary" x-on:click="closeMenu()">
          Sign in
          <Icon name="arrow-right" size="sm" />
        </a>
        <a
          href="https://auth.datum.net/ui/v2/login/register"
          class="mobile-cta-primary"
          target="_blank"
          x-on:click="closeMenu()"
        >
          Start for free
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>
      <div class="mobile-menu-social">
        <a href="https://link.datum.net/discord" class="mobile-social-link" target="_blank">
          <DiscordIcon class="mobile-social-icon" />
          Discord
        </a>
        <a href="https://github.com/datum-cloud/datum/" class="mobile-social-link" target="_blank">
          <GithubIcon class="mobile-social-icon" />
          GitHub
        </a>
      </div>
    </div>
  </div>
</div>
