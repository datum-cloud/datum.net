---
import Logo from '@assets/svgs/datum-logo-h.svg';
import MobileMenu from '@components/MobileMenu.astro';
import Icon from '@components/Icon.astro';
import LogoDropdown from '@components/LogoDropdown.astro';
import NavMenu from '@components/NavMenu.astro';
---

<section class="nav--main-container relative">
  <span class="section-line section-line--left section-line--bottom hidden 2xl:block"></span>
  <nav class="nav--main" role="navigation" aria-label="Main navigation">
    {/* Logo */}

    <div class="nav-logo-container">
      <a href="/" class="nav-logo" id="logo-link" aria-label="Datum Logo" title="Datum Logo">
        <Logo />
      </a>

      {/* Logo Download Dropdown */}
      <LogoDropdown id="logo-dropdown" triggerElementId="logo-link" />
    </div>

    {/* Desktop Menu */}
    <NavMenu />

    {/* Desktop Actions */}
    <div class="nav-actions">
      <a href="https://cloud.datum.net/" class="nav-cta-signin" data-fathom-event="Nav: Sign in">
        Sign in
        <Icon name="arrow-right-to-line" size="lg" />
      </a>

      <a
        href="https://auth.datum.net/ui/v2/login/register"
        class="nav-cta-demo"
        target="_blank"
        data-fathom-event="Nav: Book a demo"
      >
        Book a demo
        <Icon name="calendar" size="lg" />
      </a>

      {
        /*
      <Button
        class="btn btn--alpha"
        icon={{ name: 'arrow-right-to-line', size: 'md' }}
        text="Sign in"
        href="https://cloud.datum.net/"
        data-fathom-event="Nav: Sign in"
      />

      <Button
        class="btn btn--midnight-fjord"
        icon={{ name: 'calendar', size: 'md' }}
        text="Book a demo"
        href="/demo"
        data-fathom-event="Nav: Book a Demo"
      />
      */
      }
    </div>

    {/* Mobile menu — deferred so it is never emitted into static HTML */}
    <MobileMenu server:defer />
  </nav>

  <div class="nav-dropdown-backdrop" aria-hidden="true"></div>
</section>
