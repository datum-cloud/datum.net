---
import Logo from '@assets/svgs/datum-logo-h.svg';
import MobileMenu from '@components/MobileMenu.astro';
import Icon from '@components/Icon.astro';
import LogoDropdown from '@components/LogoDropdown.astro';
import NavMenu from '@components/NavMenu.astro';
---

<section class="nav--main-container relative">
  <nav class="nav--main" role="navigation" aria-label="Main navigation">
    {/* Logo */}

    <div class="nav-logo-container">
      <a href="/" class="nav-logo" id="logo-link" aria-label="Datum Logo" title="Datum Logo">
        <Logo />
      </a>

      {/* Logo Download Dropdown */}
      <LogoDropdown id="logo-dropdown" triggerElementId="logo-link" />
    </div>

    {/* Desktop Menu */}
    <NavMenu />

    {/* Desktop Actions */}
    <div class="nav-actions">
      <a href="https://cloud.datum.net/" class="nav-cta-signin" data-rybbit-event="Nav: Sign in">
        Sign in
        <Icon name="arrow-right-to-line" size="md" class="text-canyon-clay hidden lg:inline-flex" />
      </a>

      <a href="/demo" class="nav-cta-demo" data-rybbit-event="Nav: Book a demo">
        <span class="hidden lg:inline-flex">Book a demo</span>
        <span class="inline-flex lg:hidden">Demo</span>
        <Icon name="calendar" size="md" class="hidden lg:inline-flex" />
      </a>
    </div>

    {/* Mobile menu — inside <template> so it is inert in static HTML and invisible to crawlers */}
    <template id="mobile-menu-template">
      <MobileMenu />
    </template>
    <div id="mobile-menu-mount" class="md:hidden"></div>
    <script is:inline>
      (function () {
        var tpl = document.getElementById('mobile-menu-template');
        var mount = document.getElementById('mobile-menu-mount');
        if (tpl && mount) mount.appendChild(tpl.content.cloneNode(true));
      })();
    </script>
  </nav>

  <div class="nav-dropdown-backdrop" aria-hidden="true"></div>
</section>

<script>
  const syncNavDropdownBackdropTop = () => {
    const container = document.querySelector('.nav--main-container');
    if (!container) return;
    document.documentElement.style.setProperty(
      '--nav-dropdown-backdrop-top',
      `${container.getBoundingClientRect().bottom}px`
    );
  };

  const initNavDropdownBackdropTop = () => {
    const container = document.querySelector('.nav--main-container');
    if (!container) return;

    syncNavDropdownBackdropTop();

    window.addEventListener('resize', syncNavDropdownBackdropTop, { passive: true });
    window.addEventListener('scroll', syncNavDropdownBackdropTop, { passive: true });

    new ResizeObserver(syncNavDropdownBackdropTop).observe(container);

    const announcement = document.getElementById('announcement');
    if (announcement) {
      new ResizeObserver(syncNavDropdownBackdropTop).observe(announcement);
    }
  };

  initNavDropdownBackdropTop();
  document.addEventListener('alpine:initialized', syncNavDropdownBackdropTop);
</script>
