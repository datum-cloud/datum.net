---
// src/components/events/Card.astro
// Events overview: category entry cards + interactive calendar

import { fetchEvents } from '@libs/events';
import type { ContentEvent } from '@libs/events';
import EventCategoryCard from '@components/events/EventCategoryCard.astro';
import EventCalendarSection from '@components/events/EventCalendarSection.astro';
import communityHuddleCover from '@content/pages/assets/events/community-huddle.png';
import altCloudMeetupCover from '@content/pages/assets/events/alt-cloud.png';

let upcomingEvents: ContentEvent[] = [];
let pastEvents: ContentEvent[] = [];
let error: string | null = null;

try {
  const result = await fetchEvents();
  upcomingEvents = result.upcoming;
  pastEvents = result.past;
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to fetch events';
  console.error('Error loading events:', e);
}
---

{
  error ? (
    <div class="events-error">
      <p>Unable to load events. Please try again later.</p>
    </div>
  ) : (
    <div class="events-overview">
      <div class="events-category-cards">
        <EventCategoryCard
          title="Monthly Community Huddle"
          href="/events/community-huddles/"
          badge="Virtual"
          badgeIcon="video"
          imageSrc={communityHuddleCover}
          imageAlt="Community Huddle"
          colorVariant="clay"
        />
        <EventCategoryCard
          title="Alt Cloud Meetups"
          href="/events/alt-cloud-meetups/"
          badge="In person"
          badgeIcon="map-pin"
          imageSrc={altCloudMeetupCover}
          imageAlt="Alt Cloud Meetups"
          colorVariant="forest"
        />
      </div>
      <h3 class="datum-text-7xl mb-0 text-center">Find us at:</h3>
      <EventCalendarSection upcoming={upcomingEvents} past={pastEvents} />
    </div>
  )
}
