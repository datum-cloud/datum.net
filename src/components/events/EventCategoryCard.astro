---
// src/components/events/EventCategoryCard.astro
// Static category card linking to an event type's detail page

import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Icon from '@components/Icon.astro';

interface Props {
  title: string;
  href: string;
  badge: string;
  badgeIcon?: string;
  imageSrc: ImageMetadata;
  imageAlt: string;
  colorVariant: 'clay' | 'forest';
  class?: string;
}

const {
  title,
  href,
  badge,
  badgeIcon,
  imageSrc,
  imageAlt,
  colorVariant,
  class: className = '',
} = Astro.props as Props;

const bgClass =
  colorVariant === 'clay' ? 'event-category-card--clay' : 'event-category-card--forest';
---

<a href={href} class={`event-category-card ${bgClass} ${className}`}>
  <div class="event-category-card__content">
    <div class="event-category-card__text">
      <h2 class="event-category-card__title">{title}</h2>
      <span class="event-category-card__badge">
        {badgeIcon && <Icon name={badgeIcon} size="sm" />}
        {badge}
      </span>
    </div>
    <div class="event-category-card__arrow">
      <Icon name="circle-arrow-right" size="xl" />
    </div>
  </div>
  <div class="event-category-card__image">
    <Image
      src={imageSrc}
      alt={imageAlt}
      loading="lazy"
      class="absolute inset-0 h-full w-full object-cover"
    />
  </div>
</a>
