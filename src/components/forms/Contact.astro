---
// src/components/forms/Contact.astro
import type { FormProps } from '@/src/types/form';

const { title = 'Request access', submitLabel = 'Submit' }: FormProps = Astro.props;
---

<form class="form">
  <div class="form--header">
    <h2 class="form--title">{title}</h2>
  </div>

  <div class="form--content">
    <div class="form--fields">
      <div class="form--field">
        <label class="form--label">
          Email
          <input type="email" id="email" name="email" class="form--input" required />
        </label>
      </div>

      <div class="form--field">
        <label class="form--label">
          Name
          <input type="text" id="name" name="name" class="form--input" required />
        </label>
      </div>

      <div class="form--field">
        <label class="form--label">
          Company
          <input type="text" id="company" name="company" class="form--input" required />
        </label>
      </div>
    </div>

    <div class="form--message">
      <div class="form--field">
        <label class="form--label">
          Message
          <textarea id="message" name="message" class="form--textarea" rows="4" required></textarea>
        </label>
      </div>
    </div>

    <div class="form--actions">
      <div class="form--checkbox-container">
        <div class="form--checkbox-wrapper">
          <label class="form--checkbox-label">
            <input type="checkbox" id="email-updates" name="email-updates" class="form--checkbox" />
            Receive occasional email updates
          </label>
        </div>
      </div>
      <div>
        <button type="submit" class="btn btn--lime btn--2xl btn--center">{submitLabel}</button>
      </div>
    </div>
  </div>
</form>
