---
import type { SidebarProps } from '@/src/types/common';

const { selectedId, items } = Astro.props as SidebarProps;

const getCategory = (url: string) => {
  let urlSplit = url.split('/');
  return urlSplit[0];
};

const selectedCategory = getCategory(selectedId);

const selectedLabel =
  Object.values(items)
    .flatMap((item) => item?.childs ?? [])
    .find((child) => child.slug === selectedId)?.label ?? 'Handbook';
---

<aside class:list={['handbook-sidebar']} x-data="{ open: false }" @click.away="open = false">
  <button
    class="sidebar-mobile-toggle md:hidden"
    @click="open = !open"
    :aria-expanded="open"
    aria-controls="sidebar-menu"
  >
    <span class="sidebar-mobile-toggle--text">{selectedLabel}</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="sidebar-mobile-toggle--icon"
      aria-hidden="true"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </button>

  <nav id="sidebar-menu" class="sidebar-menu" x-show="open" x-transition x-cloak>
    <div data-state="open" data-orientation="vertical" class="menu-container" id="menu">
      {
        Object.values(items).map(
          (item: { slug: string; label: string; childs?: { slug: string; label: string }[] }) => {
            if (item) {
              return (
                <div
                  x-data={`{ isExpanded: ${selectedCategory === item.slug} }`}
                  class="menu-category"
                  id={item.slug}
                >
                  <div class="category-header">
                    <button
                      type="button"
                      class="category-button"
                      x-on:click="isExpanded = ! isExpanded"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="chevron-icon"
                        aria-hidden="true"
                        x-bind:class="isExpanded ? 'rotate-90' : ''"
                      >
                        <path d="m9 18 6-6-6-6" />
                      </svg>

                      <div class="category-title-container">
                        <span
                          class={
                            item.slug == selectedId
                              ? 'category-title category-title--active'
                              : 'category-title'
                          }
                        >
                          {item.label}
                        </span>
                      </div>
                    </button>
                  </div>

                  <ul x-show="isExpanded" x-collapse x-cloak class="menu-list">
                    {item.childs &&
                      item.childs.map((child) => {
                        return (
                          <li class="menu-item">
                            <a
                              href={`/handbook/${child.slug.endsWith('/') ? child.slug : child.slug + '/'}`}
                              class={
                                child.slug == selectedId
                                  ? 'menu-link menu-link--active'
                                  : 'menu-link'
                              }
                            >
                              {child.label}
                            </a>
                          </li>
                        );
                      })}
                  </ul>
                </div>
              );
            }
          }
        )
      }
    </div>
  </nav>
</aside>
