---
// src/components/home/HomeHero.astro
import { marked } from 'marked';
import Button from '@components/Button.astro';
import MediaLightbox from '@components/MediaLightbox.astro';
import HomeHeroGrid from '@assets/svgs/player-full.svg';
import HomeHeroGridLg from '@assets/svgs/player-full-lg.svg';
import HomeHeroGridMd from '@assets/svgs/player-full-md.svg';
import PlayerMobileArt from '@assets/svgs/player-mobile.svg';
import ButtonPlay from '@assets/svgs/button-play.svg';
import { HOMEPAGE_FEATURE_VIDEO_EMBED_URL } from '@utils/youtube';
import type { HomeHeroProps } from '@/src/types/common';

const { title = '', description = '' } = Astro.props as HomeHeroProps;
---

<section class="section--block bg-white px-7" aria-labelledby="home-hero-title">
  <div class="max-width-nav relative">
    <span class="section-line section-line--left section-line--top"></span>
    <span class="section-line section-line--left section-line--bottom"></span>
    <span class="section-line section-line--right section-line--top md:hidden"></span>
    <div
      class="home-hero-xl:right-0 absolute top-0 right-0 z-20 hidden h-full max-w-168.75 md:-right-7 md:block"
    >
      <button
        type="button"
        class="home-hero-video-card z-12"
        data-video-trigger
        data-embed-url={HOMEPAGE_FEATURE_VIDEO_EMBED_URL}
        aria-label="Play Product Overview video"
      >
        <ButtonPlay class="home-hero-video-card-play" aria-hidden="true" />
      </button>

      <HomeHeroGrid class="home-hero-xl:block z-11 hidden max-h-full" />
      <HomeHeroGridLg class="home-hero-xl:hidden z-11 hidden min-h-full lg:block" />
      <HomeHeroGridMd class="z-11 hidden min-h-full md:block lg:hidden" />
    </div>

    <div class="home-hero-layout max-width-nopad relative z-10">
      <div class="home-hero-content">
        {
          title && (
            <h1 id="home-hero-title" class="home-hero-title" set:html={marked.parseInline(title)} />
          )
        }
        {
          description && (
            <p class="home-hero-description" set:html={marked.parseInline(description)} />
          )
        }
        <div class="home-hero-actions">
          <Button
            class="btn btn--midnight-fjord"
            text="Book a demo"
            href="https://auth.datum.net/ui/v2/login/register"
            target="_blank"
            icon={{ name: 'calendar', size: 'md' }}
            iconPosition="left"
            data-fathom-event="Homepage: Book a demo"
          />
          <Button
            class="btn btn--alpha"
            text="Chat with us"
            href="https://link.datum.net/discord"
            target="_blank"
            icon={{ name: 'discord', size: 'md' }}
            iconPosition="left"
            data-fathom-event="Homepage: Chat with us"
          />
        </div>
      </div>

      <div class="home-hero-visual">
        <button
          type="button"
          class="home-hero-video-card home-hero-video-card--mobile"
          data-video-trigger
          data-embed-url={HOMEPAGE_FEATURE_VIDEO_EMBED_URL}
          aria-label="Play Product Overview video"
        >
          <PlayerMobileArt class="home-hero-video-card-art" aria-hidden="true" />
          <ButtonPlay class="home-hero-video-card-play" aria-hidden="true" />
        </button>
      </div>
    </div>
  </div>

  <MediaLightbox selector="" />
</section>
