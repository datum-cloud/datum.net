---
import { Image } from 'astro:assets';
import Icon from '@components/Icon.astro';
import VideoModal from './VideoModal.astro';
import ImageVideo from '@v1/assets/images/zac-video.png';
import { HOMEPAGE_FEATURE_VIDEO_EMBED_URL } from '@utils/youtube';
---

<div
  class="bg-midnight-fjord flex flex-row items-center gap-4 rounded-md p-2.5 pr-5 shadow-sm transition-opacity duration-300 hover:cursor-pointer hover:opacity-95 md:gap-5 hover:[&_button]:opacity-80"
  data-video-trigger
>
  <div>
    <button
      type="button"
      class="relative block transition-opacity duration-300 hover:cursor-pointer hover:opacity-80"
      aria-label="Play video"
    >
      <Icon
        name="play"
        class="absolute top-1/2 left-1/2 z-20 -translate-x-1/2 -translate-y-1/2 text-white"
      />
      <div class="video-thumb relative z-10 overflow-hidden rounded-md">
        <Image
          src={ImageVideo}
          layout="constrained"
          alt="Zac Smith"
          class="size-auto w-full max-w-42.5 min-w-35 md:min-w-42.5"
        />
        <div class="video-thumb-blend" aria-hidden="true"></div>
      </div>
    </button>
  </div>
  <div class="text-white">
    <p class="datum-text-xl mb-1.75 font-semibold text-balance">
      Prefer not to read? Have Zac explain.
    </p>
    <span class="datum-text-xs opacity-40">3 minute watch</span>
  </div>
</div>
<VideoModal />
<script is:inline define:vars={{ homepageFeatureEmbedUrl: HOMEPAGE_FEATURE_VIDEO_EMBED_URL }}>
  document.addEventListener('DOMContentLoaded', () => {
    const trigger = document.querySelector('[data-video-trigger]');
    if (!trigger) return;

    const openVideoModal = () => {
      if (window.VIDEO_MODAL_OPEN_EVENT) {
        document.dispatchEvent(
          new CustomEvent(window.VIDEO_MODAL_OPEN_EVENT, {
            detail: { embedUrl: homepageFeatureEmbedUrl },
          })
        );
      }
    };

    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      openVideoModal();
    });

    trigger.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openVideoModal();
      }
    });
  });
</script>
