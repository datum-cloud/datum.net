---
import Icon from '@components/Icon.astro';

const { class: className } = Astro.props as { class?: string };
---

<video-modal class={className}>
  <dialog aria-label="Video player">
    <div class="modal-frame">
      <button data-close-modal class="modal-close" aria-label="Close video" type="button">
        <Icon name="close" size="sm" class="modal-close-icon" />
      </button>
      <div class="modal-content" id="video-modal-content">
        <!-- Video content will be injected when opened -->
      </div>
    </div>
  </dialog>
</video-modal>

<script>
  import {
    HOMEPAGE_FEATURE_VIDEO_EMBED_URL,
    sanitizeYoutubeEmbedUrlForIframe,
  } from '@utils/youtube';

  const VIDEO_MODAL_OPEN_EVENT = 'video-modal-open';
  const VIDEO_MODAL_CLOSE_EVENT = 'video-modal-close';

  declare global {
    interface Window {
      VIDEO_MODAL_OPEN_EVENT: string;
      VIDEO_MODAL_CLOSE_EVENT: string;
    }

    interface CustomEventMap {
      'video-modal-open': CustomEvent<{ embedUrl?: string }>;
      'video-modal-close': CustomEvent;
    }
  }

  const VIDEO_MODAL_HASH = '#video-modal';

  function resolveEmbedUrl(detail?: { embedUrl?: string }): string {
    const fromEvent = detail?.embedUrl;
    if (fromEvent) {
      const safe = sanitizeYoutubeEmbedUrlForIframe(fromEvent.trim());
      if (safe) return safe;
    }
    return sanitizeYoutubeEmbedUrlForIframe(HOMEPAGE_FEATURE_VIDEO_EMBED_URL)!;
  }

  class VideoModal extends HTMLElement {
    dialog: HTMLDialogElement;
    dialogFrame: HTMLElement;
    closeBtn: HTMLButtonElement;
    contentContainer: HTMLElement;
    dialogOpenedAt: number = 0;

    constructor() {
      super();
      this.dialog = this.querySelector('dialog')!;
      this.dialogFrame = this.querySelector('.modal-frame')!;
      this.closeBtn = this.querySelector<HTMLButtonElement>('button[data-close-modal]')!;
      this.contentContainer = this.querySelector<HTMLElement>('#video-modal-content')!;

      this.setupEventListeners();
    }

    connectedCallback() {
      if (window.location.hash === VIDEO_MODAL_HASH) {
        requestAnimationFrame(() => this.openModal());
      }
    }

    setupEventListeners() {
      this.closeBtn.addEventListener('click', () => this.closeModal());
      window.addEventListener('popstate', () => {
        if (this.dialog.open && window.location.hash !== VIDEO_MODAL_HASH) this.closeModal();
      });

      this.dialog.addEventListener('close', () => {
        document.body.toggleAttribute('data-video-modal-open', false);
        window.removeEventListener('click', this.onClick);
        this.clearContent();
        if (window.location.hash === VIDEO_MODAL_HASH) {
          history.replaceState(null, '', window.location.pathname + window.location.search);
        }
        document.dispatchEvent(new CustomEvent(VIDEO_MODAL_CLOSE_EVENT));
      });

      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.dialog.open) {
          this.closeModal();
          e.preventDefault();
        }
      });
    }

    onClick = (event: MouseEvent) => {
      const target = event.target as HTMLElement;
      const isLink = 'href' in (target || {});
      const isOutsideDialog = document.body.contains(target) && !this.dialogFrame.contains(target);

      const isInDialog = target.closest('dialog') !== null;
      const isInDialogFrame = target.closest('.modal-frame') !== null;
      const isDialogBackdropClick = isInDialog && !isInDialogFrame;

      const clickTime = Date.now();
      const timeSinceOpen = clickTime - this.dialogOpenedAt;
      const isTooSoon = timeSinceOpen < 300;

      if (isDialogBackdropClick) {
        this.closeModal();
      } else if ((isLink || isOutsideDialog) && !isTooSoon) {
        this.closeModal();
      }
    };

    openModal(detail?: { embedUrl?: string }) {
      const embedUrl = resolveEmbedUrl(detail);
      this.populateContent(embedUrl);
      this.dialog.showModal();
      document.body.toggleAttribute('data-video-modal-open', true);
      this.dialogOpenedAt = Date.now();
      if (window.location.hash !== VIDEO_MODAL_HASH) {
        history.replaceState(
          null,
          '',
          window.location.pathname + window.location.search + VIDEO_MODAL_HASH
        );
      }
      setTimeout(() => window.addEventListener('click', this.onClick), 100);
    }

    closeModal() {
      this.dialog.close();
    }

    populateContent(embedUrl: string) {
      const safe = sanitizeYoutubeEmbedUrlForIframe(embedUrl);
      if (!safe) return;
      this.contentContainer.innerHTML = `
        <div class="modal-embed-wrapper">
          <iframe
            width="560"
            height="315"
            src="${safe.replace(/"/g, '&quot;')}"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>
      `;
    }

    clearContent() {
      this.contentContainer.innerHTML = '';
    }
  }

  if (!customElements.get('video-modal')) {
    customElements.define('video-modal', VideoModal);
  }

  function firstVideoModalEl(): VideoModal | null {
    return document.querySelector('video-modal');
  }

  if (!(globalThis as { __videoModalDocHooks?: boolean }).__videoModalDocHooks) {
    (globalThis as { __videoModalDocHooks?: boolean }).__videoModalDocHooks = true;

    document.addEventListener(VIDEO_MODAL_OPEN_EVENT, (ev: Event) => {
      const detail = (ev as CustomEvent<{ embedUrl?: string }>).detail;
      firstVideoModalEl()?.openModal(detail);
    });

    document.addEventListener('click', (e: MouseEvent) => {
      const t = (e.target as HTMLElement)?.closest?.('[data-video-recording-trigger]');
      if (!t) return;
      const embed = t.getAttribute('data-embed-url');
      if (!embed) return;
      e.preventDefault();
      const safe = sanitizeYoutubeEmbedUrlForIframe(embed);
      if (!safe) return;
      document.dispatchEvent(
        new CustomEvent(VIDEO_MODAL_OPEN_EVENT, { detail: { embedUrl: safe } })
      );
    });
  }

  window.VIDEO_MODAL_OPEN_EVENT = VIDEO_MODAL_OPEN_EVENT;
  window.VIDEO_MODAL_CLOSE_EVENT = VIDEO_MODAL_CLOSE_EVENT;
</script>
