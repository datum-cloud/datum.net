---
// src/components/locations/LocationsList.astro
import locations from '@data/locations.json';
import SectionLine from '@components/SectionLine.astro';

const groupMeta: Record<string, { name: string; inline?: boolean }> = {
  NA: { name: 'North America' },
  LATAM: { name: 'Latin America' },
  EU: { name: 'Europe' },
  MEA: { name: 'Middle East & Africa', inline: true },
  APAC: { name: 'Asia Pacific' },
};

const groupOrder = ['NA', 'LATAM', 'EU', 'MEA', 'APAC'];

const grouped = groupOrder.map((key) => ({
  key,
  ...groupMeta[key],
  items: locations
    .filter((loc) => loc.group === key)
    .sort((a, b) => a.metro.localeCompare(b.metro)),
}));
---

<div class="relative">
  <SectionLine left top overlap />
  <SectionLine right bottom overlap />

  <div class="locations-list">
    {
      grouped.map((group) => (
        <div class="locations-list--group">
          <div class="locations-list--header-row">
            <h3 class="locations-list--header">
              {group.inline ? (
                <>
                  {group.name} ({group.key})
                </>
              ) : (
                <>
                  {group.name}
                  <br />
                  <span>({group.key})</span>
                </>
              )}
            </h3>
          </div>
          <div class="locations-list--items-row">
            <ul class="locations-list--items">
              {group.items.map((loc) => (
                <li class="locations-list--item">{loc.metro}</li>
              ))}
            </ul>
          </div>
        </div>
      ))
    }
  </div>
</div>
<script>
  (function initSplitFlap() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const UPPERCASE = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const LOWERCASE = 'abcdefghijklmnopqrstuvwxyz';
    const SCRAMBLE_MS = 1100;
    const STAGGER_MS = 120;

    function randomChar(ch: string) {
      const pool = ch === ch.toUpperCase() ? UPPERCASE : LOWERCASE;
      return pool[Math.floor(Math.random() * pool.length)];
    }

    function scrambleEl(el: HTMLElement) {
      const target = el.textContent ?? '';

      // Prevent layout jank from variable-width scrambled chars
      const rect = el.getBoundingClientRect();
      el.style.display = 'inline-block';
      el.style.width = `${rect.width}px`;
      el.style.minHeight = `${rect.height}px`;
      el.style.whiteSpace = 'nowrap';
      el.style.overflow = 'hidden';

      const start = performance.now();

      function tick(now: number) {
        const elapsed = now - start;
        let result = '';
        let allDone = true;

        for (let i = 0; i < target.length; i++) {
          const ch = target[i];
          if (ch === ' ' || ch === ',') {
            result += ch;
            continue;
          }
          if (elapsed >= SCRAMBLE_MS + i * STAGGER_MS) {
            result += ch;
          } else {
            allDone = false;
            result += randomChar(ch);
          }
        }

        el.textContent = result;
        if (allDone) {
          el.textContent = target;
          el.style.display = '';
          el.style.width = '';
          el.style.minHeight = '';
          el.style.whiteSpace = '';
          el.style.overflow = '';
          return;
        }
        requestAnimationFrame(tick);
      }

      requestAnimationFrame(tick);
    }

    function triggerGroup(group: Element) {
      const items = Array.from(group.querySelectorAll<HTMLElement>('.locations-list--item'));
      items.forEach((item, i) => {
        setTimeout(() => scrambleEl(item), i * 80);
      });
    }

    document.querySelectorAll('.locations-list--group').forEach((group) => {
      let done = false;
      const obs = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting && !done) {
            done = true;
            obs.disconnect();
            triggerGroup(group);
          }
        },
        { threshold: 0.3 }
      );
      obs.observe(group);
    });
  })();
</script>
