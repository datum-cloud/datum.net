---
// src/components/roadmap/RoadmapEmptyModal.astro
// Empty release state — Figma Datum Master, node 14497:55490.
import Icon from '@components/Icon.astro';
---

<roadmap-empty-modal>
  <dialog class="roadmap-empty-modal__dialog" aria-label="Roadmap release">
    <div class="modal-frame roadmap-empty-modal__frame">
      <button type="button" data-close-modal class="modal-close" aria-label="Close">
        <Icon name="close" size="sm" class="modal-close-icon" />
      </button>
      <div class="roadmap-empty-modal__content">
        <div class="roadmap-empty-modal__header">
          <p class="roadmap-empty-modal__date" data-roadmap-empty-date></p>
          <p class="roadmap-empty-modal__title" data-roadmap-empty-title></p>
        </div>
        <p class="roadmap-empty-modal__message">
          Looks like this one's still being populated. Check back later
        </p>
      </div>
    </div>
  </dialog>
</roadmap-empty-modal>

<script>
  const OPEN_ATTR = 'data-roadmap-empty-open';
  const SLUG_ATTR = 'data-roadmap-slug';

  type RoadmapEmptyModalPayload = {
    slug: string;
    date: string;
    name: string;
    version?: string;
  };

  class RoadmapEmptyModal extends HTMLElement {
    dialog: HTMLDialogElement;
    dialogFrame: HTMLElement;
    closeBtn: HTMLButtonElement;
    elDate: HTMLElement;
    elTitle: HTMLElement;
    dialogOpenedAt = 0;
    currentSlug: string | null = null;

    constructor() {
      super();
      this.dialog = this.querySelector('dialog')!;
      this.dialogFrame = this.querySelector('.roadmap-empty-modal__frame')!;
      this.closeBtn = this.querySelector<HTMLButtonElement>('button[data-close-modal]')!;
      this.elDate = this.querySelector('[data-roadmap-empty-date]')!;
      this.elTitle = this.querySelector('[data-roadmap-empty-title]')!;
      this.setupEventListeners();
    }

    connectedCallback() {
      this.openFromHash();
    }

    setupEventListeners() {
      this.closeBtn.addEventListener('click', () => this.closeModal());
      this.dialog.addEventListener('close', () => {
        document.body.toggleAttribute('data-roadmap-empty-modal-open', false);
        window.removeEventListener('click', this.onWindowClick);
        this.currentSlug = null;
      });
      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.dialog.open) {
          this.closeModal();
          e.preventDefault();
        }
      });
      window.addEventListener('hashchange', () => this.onHashChange());
    }

    onWindowClick = (event: MouseEvent) => {
      const target = event.target as HTMLElement;
      const isInDialog = target.closest('dialog') !== null;
      const isInDialogFrame = target.closest('.roadmap-empty-modal__frame') !== null;
      const isBackdrop = isInDialog && !isInDialogFrame;
      const timeSinceOpen = Date.now() - this.dialogOpenedAt;
      if (isBackdrop || (timeSinceOpen >= 300 && !this.dialogFrame.contains(target))) {
        this.closeModal();
      }
    };

    onHashChange() {
      const slug = window.location.hash.slice(1);
      if (!slug) {
        if (this.dialog.open) this.dialog.close();
        return;
      }
      if (this.dialog.open && this.currentSlug === slug) return;
      this.openFromHash();
    }

    findTriggerBySlug(slug: string): HTMLElement | null {
      const card = document.querySelector<HTMLElement>(`[${SLUG_ATTR}="${CSS.escape(slug)}"]`);
      if (!card) return null;
      return card.querySelector<HTMLElement>(`[${OPEN_ATTR}]`);
    }

    applyPayload(payload: RoadmapEmptyModalPayload) {
      this.elDate.textContent = payload.date;
      const versionSuffix = payload.version ? ` ${payload.version}` : '';
      this.elTitle.textContent = `${payload.name}:${versionSuffix}`;
    }

    openWithPayload(payload: RoadmapEmptyModalPayload, updateHash = true) {
      this.applyPayload(payload);
      this.currentSlug = payload.slug;
      if (updateHash) {
        history.replaceState(null, '', `#${payload.slug}`);
      }
      this.dialog.showModal();
      document.body.toggleAttribute('data-roadmap-empty-modal-open', true);
      this.dialogOpenedAt = Date.now();
      setTimeout(() => window.addEventListener('click', this.onWindowClick), 100);
    }

    openFromTrigger(btn: HTMLElement) {
      const raw = btn.getAttribute(OPEN_ATTR);
      if (!raw) return;
      let payload: RoadmapEmptyModalPayload;
      try {
        payload = JSON.parse(raw) as RoadmapEmptyModalPayload;
      } catch {
        return;
      }
      if (!payload.slug) return;
      this.openWithPayload(payload);
    }

    openFromHash() {
      const slug = window.location.hash.slice(1);
      if (!slug) return;
      const trigger = this.findTriggerBySlug(slug);
      if (!trigger) return;
      const raw = trigger.getAttribute(OPEN_ATTR);
      if (!raw) return;
      let payload: RoadmapEmptyModalPayload;
      try {
        payload = JSON.parse(raw) as RoadmapEmptyModalPayload;
      } catch {
        return;
      }
      if (!payload.slug || payload.slug !== slug) return;
      if (this.dialog.open && this.currentSlug === slug) return;
      this.openWithPayload(payload, false);
    }

    closeModal() {
      const slug = this.currentSlug;
      if (this.dialog.open) {
        this.dialog.close();
      }
      if (slug && window.location.hash === `#${slug}`) {
        history.replaceState(null, '', window.location.pathname + window.location.search);
      }
    }
  }

  if (!customElements.get('roadmap-empty-modal')) {
    customElements.define('roadmap-empty-modal', RoadmapEmptyModal);
  }

  if (!(globalThis as { __roadmapEmptyOpenHook?: boolean }).__roadmapEmptyOpenHook) {
    (globalThis as { __roadmapEmptyOpenHook?: boolean }).__roadmapEmptyOpenHook = true;
    document.addEventListener('click', (e: MouseEvent) => {
      const t = (e.target as HTMLElement)?.closest?.(`[${OPEN_ATTR}]`);
      if (!t) return;
      const host = document.querySelector('roadmap-empty-modal');
      if (!host || !('openFromTrigger' in host)) return;
      e.preventDefault();
      (host as RoadmapEmptyModal).openFromTrigger(t as HTMLElement);
    });
  }
</script>
