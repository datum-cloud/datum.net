---
// src/components/roadmap/RoadmapTabNav.astro

interface Props {
  activeTab: 'releases' | 'backlog';
}

const { activeTab } = Astro.props as Props;
---

<nav aria-label="Roadmap sections" class="roadmap-tab-nav">
  <a
    href="/roadmap"
    class="roadmap-tab-nav--item"
    aria-current={activeTab === 'releases' ? 'page' : undefined}
  >
    <span
      class:list={[
        'roadmap-tab-nav--content',
        activeTab === 'releases' && 'roadmap-tab-nav--content--active',
      ]}
    >
      Releases
    </span>
  </a>
  <a
    href="/backlog"
    class="roadmap-tab-nav--item roadmap-tab-nav--item--standard"
    aria-current={activeTab === 'backlog' ? 'page' : undefined}
  >
    <span
      class:list={[
        'roadmap-tab-nav--content',
        activeTab === 'backlog' && 'roadmap-tab-nav--content--active',
      ]}
    >
      Backlog
    </span>
  </a>
  <span class="roadmap-tab-nav--spacer" aria-hidden="true"></span>
</nav>
