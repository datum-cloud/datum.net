        </p>
      )
    }

    <h2>Strapi Fallback</h2>
    {
      bySource['strapi-fallback'].length > 0 ? (
        <table border="1" cellpadding="8" style="border-collapse: collapse">
          <thead>
            <tr>
              <th>Key</th>
              <th>Size</th>
              <th>Expires</th>
              <th>Status</th>
              <th>Preview</th>
            </tr>
          </thead>
          <tbody>
            {bySource['strapi-fallback'].map((e) => (
              <tr>
                <td>
                  <code>{e.key}</code>
                </td>
                <td>{formatSize(e.size)}</td>
                <td>{formatExpiry(e.expiresAt)}</td>
                <td>{e.expired ? '⚠️ expired' : '✓ valid'}</td>
                <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis">
                  <code>{e.preview}</code>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p>
          <em>No Strapi fallback cache entries</em>
        </p>
      )
    }

    {
      bySource.other.length > 0 && (
        <>
          <h2>Other</h2>
          <table border="1" cellpadding="8" style="border-collapse: collapse">
            <thead>
              <tr>
                <th>Key</th>
                <th>Size</th>
                <th>Expires</th>
                <th>Status</th>
                <th>Preview</th>
              </tr>
            </thead>
            <tbody>
              {bySource.other.map((e) => (
                <tr>
                  <td>
                    <code>{e.key}</code>
                  </td>
                  <td>{formatSize(e.size)}</td>
                  <td>{formatExpiry(e.expiresAt)}</td>
                  <td>{e.expired ? '⚠️ expired' : '✓ valid'}</td>
                  <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis">
                    <code>{e.preview}</code>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </>
      )
    }

    <p style="margin-top: 2rem">
      <a href="/dev/">← Back to Dev</a>
    </p>
  </body>
</html>
