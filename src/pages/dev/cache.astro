                  <code>{e.key}</code>
                </td>
                <td>{formatSize(e.size)}</td>
                <td>{formatExpiry(e.expiresAt)}</td>
                <td>{e.expired ? '⚠️ expired' : '✓ valid'}</td>
                <td>
                  <code>{e.preview}</code>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p>
          <em>No Stargazer cache entries</em>
        </p>
      )
    }

    <h2>Strapi</h2>
    {
      bySource.strapi.length > 0 ? (
        <table border="1" cellpadding="8" style="border-collapse: collapse">
          <thead>
            <tr>
              <th>Key</th>
              <th>Size</th>
              <th>Expires</th>
              <th>Status</th>
              <th>Preview</th>
            </tr>
          </thead>
          <tbody>
            {bySource.strapi.map((e) => (
              <tr>
                <td>
                  <code>{e.key}</code>
                </td>
                <td>{formatSize(e.size)}</td>
                <td>{formatExpiry(e.expiresAt)}</td>
                <td>{e.expired ? '⚠️ expired' : '✓ valid'}</td>
                <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis">
                  <code>{e.preview}</code>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
