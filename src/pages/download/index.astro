---
// src/pages/download/index.astro
export const prerender = false;

Astro.response.headers.set('Cache-Control', 'no-store');
Astro.response.headers.set('Vary', 'User-Agent');
return Astro.redirect(
  (() => {
    const ua = Astro.request.headers.get('user-agent') ?? '';
    if (/Windows/i.test(ua)) return '/downloads/windows/';
    if (/Linux/i.test(ua) && !/Android/i.test(ua)) return '/download/linux/';
    return '/download/mac-os/';
  })(),
  302
);
---
