---
import '@v1/styles/page-essentials.css';
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import Footer from '@components/Footer.astro';
import SecondaryTabNav from '@components/SecondaryTabNav.astro';
import { getCollectionEntry } from '@utils/collectionUtils';
import { getCollection } from 'astro:content';
import FAQ from '@components/FAQ.astro';
import Icon from '@components/Icon.astro';
import features from '@data/features.json';

const page = await getCollectionEntry('pages', 'essentials');

const faqs = (await getCollection('faq'))
  .filter((faq) => !faq.data.draft && faq.data.category === 'features')
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

// SEO
const fm = page.data;
const meta = fm.meta || {};
const theTitle = 'Batteries <span>included</span>';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': 'https://www.datum.net/essentials/',
      url: 'https://www.datum.net/essentials/',
      name: 'Batteries included – Enterprise-grade networking primitives',
      description: 'We think core cloud features are essential, not optional.',
      isPartOf: { '@id': 'https://www.datum.net/#organization' },
      inLanguage: 'en-US',
      dateModified: '2026-03-27',
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://www.datum.net/pricing/#faq',
      mainEntity: [
        {
          '@type': 'Question',
          name: "What's included in the free Builder tier, and will it always be free?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Yes, the Builder tier is completely free and Datum's goal is to keep it that way. It includes core programmatic capabilities for developing, protecting, and connecting applications on the internet — including AI Edge, Connectors, DNS, Domains, OTel Metrics Export, Secrets, Teams, RBAC, and Machine Accounts.",
          },
        },
        {
          '@type': 'Question',
          name: 'When does the Scaler tier launch, and how is it different from the free tier?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "The Scaler tier is coming in the first half of 2026. In addition to support and SLA guarantees, it includes features that use Datum's global backbone — such as private connections to AWS or GCP — as well as certificate management and domain connect.",
          },
        },
        {
          '@type': 'Question',
          name: "What does 'traffic usage' mean for Scaler tier pricing?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'The Scaler tier uses a pay-as-you-grow model with a base price of $20/month plus additional charges based on actual traffic usage. The plan includes $10 in usage credits to help offset initial traffic costs.',
          },
        },
        {
          '@type': 'Question',
          name: 'Who is the Provider tier for, and how much does it cost?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: "The Provider tier is designed for alt cloud providers that deliver their value directly on top of connected infrastructure. Pricing is custom. It includes everything in the Scaler plan plus Managed Cloud and BYOC options, private virtual backbones, and custom AnyCAST and IP Space. Prospective customers can schedule time with Datum's founders to learn more.",
          },
        },
      ],
    },
  ],
};
---

<Layout bodyClass={`page-${page.id}`} meta={meta} jsonLd={jsonLd}>
  <section class="datum-container">
    <Hero class="light content-alt pb-0" title={theTitle} description={fm.description}>
      <SecondaryTabNav
        slot="before-content"
        ariaLabel="Product"
        mobileLabel="Product"
        items={[
          { label: 'Features', href: '/features/', exact: true },
          { label: 'Essentials', href: '/essentials/' },
          { label: 'Pricing', href: '/pricing/' },
        ]}
      />
    </Hero>

    <div class="section--block section--block--pad bg-glacier-mist-700 pt-0">
      <div class="max-width">
        <div class="border-glacier-mist-900 border-l-2 pl-4 md:pl-12 lg:pl-16 xl:pl-20">
          <div class="essentials-header">
            <div class="section-label">Useful features_</div>
            <h2 class="section-title">At a price called <span>zero!</span></h2>
          </div>

          <div class="essentials-grid">
            {
              features.map((feature) => (
                <div class="essentials-item">
                  <div class="essentials-item-icon">
                    <Icon name={feature.icon} class="stroke-1" />
                  </div>
                  <div class="essentials-item-content">
                    <p class="essentials-item-title">{feature.title}</p>
                    <p class="essentials-item-description">{feature.description}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="section--block section--block--pad bg-glacier-mist-800">
      <div class="max-width">
        <div class="grid grid-cols-12 gap-6" x-data="{ expandedFaq: null }">
          <h2 class="datum-text-7xl col-span-12 col-start-1 md:col-span-5">
            Frequently asked questions
          </h2>
          <div class="col-span-12 md:col-span-7">
            <div class="faq-list">
              {
                faqs.map((faq, index) => {
                  return <FAQ faq={faq} index={index} />;
                })
              }
            </div>
          </div>
        </div>
      </div>
    </div>

    <Footer />
  </section>
</Layout>

<script>
  (function initHighlights() {
    function makeHighlighter(container: Element, selector: string, threshold = 0.4) {
      let isHighlighted = false;

      function highlight() {
        if (isHighlighted) return;
        isHighlighted = true;
        Array.from(container.querySelectorAll<HTMLElement>(selector)).forEach((el, i) =>
          setTimeout(() => el.classList.add('highlight-animate'), i * 80)
        );
      }

      // Fire immediately if the container is already (partially) visible on load.
      const rect = container.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom > 0) {
        highlight();
      }

      // On mobile the grid stacks into a single column and can exceed the viewport
      // height by 3×+, making a 0.4 threshold geometrically unreachable. Clamp it
      // to 90% of the max visible fraction so it always fires.
      const maxVisible = window.innerHeight / rect.height;
      const effectiveThreshold = Math.min(threshold, maxVisible * 0.9);

      new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting) highlight();
        },
        { threshold: effectiveThreshold }
      ).observe(container);

      new IntersectionObserver(
        (entries) => {
          if (!entries[0].isIntersecting) isHighlighted = false;
        },
        { threshold: 0 }
      ).observe(container);
    }

    const grid = document.querySelector('.essentials-grid');
    if (grid) makeHighlighter(grid, '.essentials-item-icon');
  })();
</script>
