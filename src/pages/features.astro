---
import '@v1/styles/page-features.css';
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import Footer from '@components/Footer.astro';
import Table from '@components/features/Table.astro';
import Cards from '@components/features/Cards.astro';

import ImageTwoMen from '@v1/assets/images/two-men.png';
import ImageLight from '@v1/assets/images/light-trail.png';

import type { FeaturesDataProps } from '@/src/types/features';

import { Image } from 'astro:assets';
import { getCollectionEntry } from '@utils/collectionUtils';
import { getEntries, getCollection } from 'astro:content';
import FAQ from '@components/FAQ.astro';
import { marked } from 'marked';

const page = await getCollectionEntry('features', 'index');
const fm = page.data;

const firstContents: Array<{
  data: FeaturesDataProps;
  body: string;
}> = fm.sections.first && (await getEntries(fm.sections.first));

const secondContents: Array<{
  data: FeaturesDataProps;
  body: string;
}> = fm.sections.second && (await getEntries(fm.sections.second));

const faqs = (await getCollection('faq'))
  .filter((faq) => !faq.data.draft && faq.data.category === 'features')
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

// SEO
const meta = fm.meta || {};
const title = fm.title ? fm.title : 'Datum Features';
const description = fm.description;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': 'https://www.datum.net/features/#webpage',
      url: 'https://www.datum.net/features/',
      name: 'Datum Features – Critical Network Infrastructure',
      description:
        'Core networking features for agents and developers: AI Edge with global points of presence, QUIC-based Connectors, DNS, Domains, Metrics Export, Audit Logs, and Kubernetes-native tooling. Forever free tier available.',
      isPartOf: { '@id': 'https://www.datum.net/#organization' },
      inLanguage: 'en-US',
      dateModified: '2026-03-20',
    },
    {
      '@type': 'SoftwareApplication',
      '@id': 'https://www.datum.net/#product',
      name: 'Datum Cloud',
      url: 'https://www.datum.net/',
      applicationCategory: 'NetworkingApplication',
      operatingSystem: 'Linux, macOS, Windows',
      description:
        'An open source network cloud providing AI Edge, QUIC-based tunnels, DNS, Domains, OTel metrics export, and Kubernetes-native control plane — built for modern alt cloud providers and AI-native teams.',
      publisher: { '@id': 'https://www.datum.net/#organization' },
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
        name: 'Builder tier',
        description:
          'Forever free tier including AI Edge and QUIC tunnels for exposing localhost to the internet.',
        url: 'https://www.datum.net/pricing/',
      },
      featureList: [
        'AI Edge — global Envoy-based edge proxy with WAF, custom hostnames, health checks, and 17+ global points of presence',
        'Connectors — zero trust QUIC tunnels built on Iroh for safely exposing localhost to the internet',
        'datumctl — Kubernetes-style CLI for authenticating and managing resources',
        'Datum MCP — self-hosted MCP server with Cursor integration for AI agents',
        'Developer Tools — macOS, Windows, and Linux desktop apps',
        'DNS — secure authoritative DNS served across 17 global locations',
        'Domains — programmatic domain management across providers',
        'Metrics Export — OpenTelemetry metrics export to Grafana Cloud with prebuilt dashboards',
        'Audit & Activity Logs — production-grade activity and audit logging',
        'AGPLv3 License — open source with community contributions',
      ],
      softwareVersion: '2025',
      license: 'https://www.gnu.org/licenses/agpl-3.0.html',
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://www.datum.net/features/#faq',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How mature is Datum Cloud?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Datum is an early stage company and its product is evolving steadily. Core features like additional Connectors, Galactic VPC, and Compute are in progress, alongside platform features for enterprise readiness and operational scale.',
          },
        },
        {
          '@type': 'Question',
          name: 'Why is Datum currently free?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Datum offers a forever-free service tier as a core commitment. As the product matures, all features will be enabled in the free tier with reasonable usage limits. A paid plan with an SLA and additional deployment models are planned for later in 2026.',
          },
        },
        {
          '@type': 'Question',
          name: 'What deployment models does Datum Cloud offer?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Datum currently offers a public cloud model (multi-tenant at the control plane and network level) and open source. A managed cloud offering (single-tenant control plane) and a bring-your-own-cloud (BYOC) model are planned pending design partner demand.',
          },
        },
        {
          '@type': 'Question',
          name: 'How does Datum Cloud compare to public clouds and CDNs?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Datum offers features that mirror aspects of large public clouds and CDNs — an edge proxy, reverse tunnel, DNS, global reach, and a high-performance backbone — but is built specifically for modern alt cloud providers with an open, AI-native, neutral strategy.',
          },
        },
        {
          '@type': 'Question',
          name: "What are the 'internet superpowers' Datum talks about?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Internet superpowers refer to networking capabilities like peering, interconnection, and deterministic routing that large tech companies use to control traffic flow, improve performance, lower costs, and comply with regulation. Datum's mission is to make these available to every developer, agent, and builder.",
          },
        },
        {
          '@type': 'Question',
          name: "What is Datum's relationship with Kubernetes?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: "Datum's control plane is built on Kubernetes Custom Resource Definitions (CRDs). You don't need to use Kubernetes to use Datum Cloud, but it will feel natural if you do. Kubernetes familiarity also means LLMs like Claude have a more seamless and accurate experience working with Datum's APIs.",
          },
        },
        {
          '@type': 'Question',
          name: "How is Datum's infrastructure structured?",
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Datum deploys infrastructure at top internet aggregation points globally, packaged into Regions and Availability Zones (AZs). Each Region represents a geographic and network boundary; each AZ provides independent capacity within that Region. Regions use a country-anchored naming format: two-letter ISO country code, cardinal direction, region index, and AZ identifier (e.g. us-central-1a).',
          },
        },
      ],
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  bodyClass="page-features"
  meta={meta}
  jsonLd={jsonLd}
>
  <section class="datum-container overflow-clip">
    <Hero
      class="light"
      iconName="goal"
      title={title}
      description={description}
      subtitle={fm.subtitle}
    />

    {
      firstContents[0] && (
        <div class="section--block section--block--pad bg-midnight-fjord dark pb-22">
          <div class="absolute top-1/2 -right-26 z-20 inline-block max-w-149 -translate-y-1/2">
            <Image
              src={ImageLight}
              alt="Light Trail"
              class="relative h-auto w-[670px] -rotate-45"
            />
          </div>
          <div class="max-width">
            <Table>
              <h2 slot="header">{firstContents[0].data.title}</h2>

              {firstContents[0].data.keyFeatures && (
                <Fragment slot="features">
                  <Fragment set:html={marked.parse(firstContents[0].body)} />
                  <h3>Key features</h3>
                  <ul>
                    {firstContents[0].data.keyFeatures.map((feature) => (
                      <li>{feature}</li>
                    ))}
                  </ul>
                </Fragment>
              )}

              {firstContents[0].data.readTheDocs && (
                <Fragment slot="docs">
                  <h3>Next steps</h3>
                  <ul>
                    {firstContents[0].data.readTheDocs.map((item) => (
                      <li>
                        <a href={item.url}>{item.label}</a>
                      </li>
                    ))}
                  </ul>
                </Fragment>
              )}
            </Table>
          </div>
        </div>
      )
    }

    {
      firstContents[1] && (
        <div class="section--block section--block--pad bg-midnight-fjord dark overflow-visible pt-0">
          <div class="max-width relative">
            <div class="absolute top-0 left-15 z-30 inline-block -translate-y-full">
              <Image
                src={ImageTwoMen}
                alt="Two Men"
                class="relative h-auto w-[60px] md:w-[110px]"
                data-scroll-effect="parallax"
                data-scroll-speed="0.1"
                data-scroll-direction="down"
                data-viewport-offset="-200"
                data-max-movement="50"
              />
            </div>
            <Table class="z-40">
              <h2 slot="header">{firstContents[1].data.title}</h2>

              {firstContents[1].data.keyFeatures && (
                <Fragment slot="features">
                  <Fragment set:html={marked.parse(firstContents[1].body)} />
                  <h3>Key features</h3>
                  <ul>
                    {firstContents[1].data.keyFeatures.map((feature) => (
                      <li>{feature}</li>
                    ))}
                  </ul>
                </Fragment>
              )}

              {firstContents[1].data.readTheDocs && (
                <Fragment slot="docs">
                  <h3>Next steps</h3>
                  <ul>
                    {firstContents[1].data.readTheDocs.map((item) => (
                      <li>
                        <a href={item.url}>{item.label}</a>
                      </li>
                    ))}
                  </ul>
                </Fragment>
              )}
            </Table>
          </div>

          <div class="absolute bottom-1/2 -left-30 z-20 hidden w-auto max-w-2/3 translate-y-1/2 md:block">
            <Image
              src={ImageLight}
              alt="Light Trail"
              class="relative h-auto w-full max-w-[650px]"
            />
          </div>
        </div>
      )
    }

    {
      secondContents && (
        <div class="section--block section--block--pad bg-glacier-mist-700 pb-0">
          <div class="max-width">
            <div class="border-midnight-fjord border bg-white p-7 md:p-12 xl:p-16">
              <Cards features={secondContents} />
            </div>
          </div>
        </div>
      )
    }
    <div class="section--block section--block--pad bg-glacier-mist-700">
      <div class="max-width">
        <div class="grid grid-cols-12 gap-6" x-data="{ expandedFaq: null }">
          <h2 class="datum-text-7xl col-span-12 col-start-1 md:col-span-5">Common Questions</h2>
          <div class="col-span-12 md:col-span-7">
            <div class="faq-list">
              {
                faqs.map((faq, index) => {
                  return <FAQ faq={faq} index={index} />;
                })
              }
            </div>
          </div>
        </div>
      </div>
    </div>

    <Footer />
  </section>
</Layout>
