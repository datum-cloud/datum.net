---
import '@v1/styles/page-legal.css';
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import Footer from '@components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const legal = await getCollection('legal');

  return legal.map((entry) => {
    return {
      params: {
        slug: entry.id,
      },
      props: { entry, legal },
    };
  });
}

const page = Astro.props.entry;
const allLegal = Astro.props.legal;

// SEO
const fm = page.data;
const meta = fm.meta || {};
const { Content } = await render(page);
const title = fm.title ? fm.title : 'Datum - Privacy Policy';
const description = fm.description;

// Build ordered side nav (matching design order)
const navOrder = ['terms', 'privacy', 'aup', 'dpa', 'subprocessors'];
const sortedLegal = [...allLegal].sort((a, b) => {
  const ai = navOrder.indexOf(a.id);
  const bi = navOrder.indexOf(b.id);
  const aIdx = ai === -1 ? navOrder.length : ai;
  const bIdx = bi === -1 ? navOrder.length : bi;
  return aIdx - bIdx;
});
---

<Layout
  title={title}
  description={description}
  bodyClass={`page-legal page-legal--${page.id}`}
  meta={meta}
>
  <section class="datum-container">
    <Hero
      class="light bg-glacier-mist-800 [&_.hero--main-content-title]:max-w-none"
      title="Privacy Policies and Security Practices"
    />

    <div class="section--block section--block--pad bg-glacier-mist-700 pt-0">
      <div class="max-width">
        <div class="legal-layout">
          <!-- Side Nav -->
          <aside
            class="legal-sidenav"
            x-data="{ open: false }"
            @click.away="open = false"
            @resize.window="if (window.innerWidth >= 768) open = false"
          >
            <button
              class="legal-sidenav-toggle md:hidden"
              @click="open = !open"
              :aria-expanded="open"
              aria-controls="legal-sidenav-menu"
            >
              <span class="legal-sidenav-toggle--text">Menu</span>
              <svg
                x-show="!open"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"
                ></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
              >
              <svg
                x-show="open"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"
                ></line></svg
              >
            </button>

            <nav id="legal-sidenav-menu" x-show="open" x-transition style="display: none;">
              {
                sortedLegal.map((entry) => (
                  <a
                    href={`/legal/${entry.id}/`}
                    class:list={[
                      'legal-sidenav-item',
                      { 'legal-sidenav-item--active': entry.id === page.id },
                    ]}
                    @click="open = false"
                  >
                    {entry.data.title}
                  </a>
                ))
              }
            </nav>
          </aside>

          <!-- Main Content -->
          <main class="legal-content">
            <Content />
          </main>

          <!-- On this page (reserved column) -->
          <!-- <div class="legal-on-this-page" aria-hidden="true"></div> -->
        </div>
      </div>
    </div>

    <Footer showCTA={false} />
  </section>
</Layout>
