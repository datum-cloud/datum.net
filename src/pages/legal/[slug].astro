---
import '@v1/styles/page-legal.css';
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import Footer from '@components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const legal = await getCollection('legal');

  return legal.map((entry) => {
    return {
      params: {
        slug: entry.id,
      },
      props: { entry, legal },
    };
  });
}

const page = Astro.props.entry;
const allLegal = Astro.props.legal;

// SEO
const fm = page.data;
const meta = fm.meta || {};
const { Content } = await render(page);
const title = fm.title ? fm.title : 'Datum - Privacy Policy';
const description = fm.description;

// Build ordered side nav (matching design order)
const navOrder = ['terms', 'privacy', 'aup', 'dpa', 'subprocessors'];
const sortedLegal = [...allLegal].sort((a, b) => {
  const ai = navOrder.indexOf(a.id);
  const bi = navOrder.indexOf(b.id);
  const aIdx = ai === -1 ? navOrder.length : ai;
  const bIdx = bi === -1 ? navOrder.length : bi;
  return aIdx - bIdx;
});
---

<Layout
  title={title}
  description={description}
  bodyClass={`page-legal page-legal--${page.id}`}
  meta={meta}
>
  <section class="datum-container">
    <Hero
      class="light legal-hero [&_.hero--main-content-inner]:pb-16 [&_.hero--main-content-title]:max-w-none [&_.hero--main-content-title]:whitespace-nowrap"
      title="Privacy Policies and Security Practices"
    />

    <div class="bg-glacier-mist-700">
      <div class="legal-layout">
        <!-- Side Nav -->
        <aside class="legal-sidenav">
          <nav>
            {
              sortedLegal.map((entry) => (
                <a
                  href={`/legal/${entry.id}`}
                  class:list={[
                    'legal-sidenav-item',
                    { 'legal-sidenav-item--active': entry.id === page.id },
                  ]}
                >
                  {entry.data.title}
                </a>
              ))
            }
          </nav>
        </aside>

        <!-- Main Content -->
        <main class="legal-content">
          <Content />
        </main>

        <!-- On this page (reserved column) -->
        <div class="legal-on-this-page" aria-hidden="true"></div>
      </div>
    </div>

    <Footer showCTA={false} />
  </section>
</Layout>
