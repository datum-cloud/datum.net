---
// src/pages/locations.astro
import '@styles/page-locations.css';
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import Footer from '@components/Footer.astro';
import LocationsMap from '@components/locations/LocationsMap.astro';
import LocationsList from '@components/locations/LocationsList.astro';
import SecondaryTabNav from '@components/SecondaryTabNav.astro';
import SectionGroup from '@components/SectionGroup.astro';
import ModuleConnector from '@components/home/ModuleConnector.astro';
import navigation from '@data/navigation.json';

import { getCollectionEntry } from '@utils/collectionUtils';

const page = await getCollectionEntry('pages', 'locations');
const fm = page.data;

// SEO
const meta = fm.meta || {};
const title = fm.title ? fm.title : 'Datum Locations';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': 'https://www.datum.net/locations/#webpage',
      url: 'https://www.datum.net/locations/',
      name: 'Datum Cloud Global Locations',
      description:
        'Datum deploys infrastructure at the most important internet peering points globally with regions across North America, Latin America, Europe, Middle East & Africa, and Asia Pacific.',
      isPartOf: { '@id': 'https://www.datum.net/#organization' },
      inLanguage: 'en-US',
      dateModified: '2026-04-01',
    },
  ],
};
---

<Layout bodyClass="page-locations" meta={meta} jsonLd={jsonLd}>
  <section class="datum-container">
    <Hero
      class="light content-alt pb-0"
      title={title}
      description={fm.description}
      showSectionLines={true}
    >
      <SecondaryTabNav
        slot="before-content"
        ariaLabel="Product"
        mobileLabel="Product"
        items={navigation.productTabs}
        variant="locations"
      />
    </Hero>

    <section
      class="section--block border-silver-mist bg-platinum section--block--x-pad overflow-hidden border-t"
    >
      <SectionGroup
        label="NAP"
        eyebrowVariant="app"
        class="small-pad"
        listClass="section-group-list max-w-8xl "
      >
        <div class="spacing-pad relative">
          <section class="max-width max-w-6xl">
            <LocationsMap />
          </section>
          <LocationsList />
        </div>
      </SectionGroup>
    </section>

    <ModuleConnector />

    <Footer />
  </section>
</Layout>

<script>
  (function initMapTilt() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const elFound = document.querySelector<HTMLElement>('.locations-map');
    if (!elFound) return;
    const el: HTMLElement = elFound;

    el.style.opacity = '0';

    const ANGLE = 35;

    let rafId = 0;

    function update() {
      const rect = el.getBoundingClientRect();
      const vh = window.innerHeight;

      const startY = vh;
      const endY = (vh - rect.height) / 2;
      const progress =
        endY === startY ? 1 : Math.max(0, Math.min(1, (startY - rect.top) / (startY - endY)));

      if (progress >= 1) {
        el.style.transform = '';
      } else {
        const angle = ANGLE * (1 - progress);
        el.style.transform = `perspective(1400px) rotateX(${angle.toFixed(2)}deg)`;
      }
    }

    update();
    el.style.opacity = '1';

    window.addEventListener(
      'scroll',
      () => {
        if (rafId) return;
        rafId = requestAnimationFrame(() => {
          update();
          rafId = 0;
        });
      },
      { passive: true }
    );
    window.addEventListener('resize', update, { passive: true });
  })();
</script>
