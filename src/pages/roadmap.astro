---
// src/pages/roadmap.astro
export const prerender = false;

import '@v1/styles/page-roadmap.css';
import { getCollectionEntry } from '@utils/collectionUtils';
import { fetchStrapiRoadmaps } from '@libs/strapi';

import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import Footer from '@components/Footer.astro';
import SecondaryTabNav from '@components/SecondaryTabNav.astro';
import RoadmapGrid from '@components/roadmap/RoadmapGrid.astro';
import RoadmapEmptyModal from '@components/roadmap/RoadmapEmptyModal.astro';
import RoadmapViewFilter from '@components/roadmap/RoadmapViewFilter.astro';

if (Astro.url.searchParams.get('tab') === 'backlog') {
  return Astro.redirect('/backlog', 301);
}

const page = await getCollectionEntry('pages', 'roadmap');
const fm = page.data;
const meta = fm.meta || {};
const description = fm.description;
const heroYear = new Date().getFullYear();
const heroTitle = `${heroYear} Roadmap`;

const roadmaps = await fetchStrapiRoadmaps();
---

<Layout title={heroTitle} description={description} bodyClass="page-roadmap" meta={meta}>
  <section class="datum-container">
    <Hero class="light content-alt" title={heroTitle} description={description} />

    <div class="section--block section--block--pad bg-glacier-mist-700 pt-0">
      <div class="max-width">
        <div class="mb-8 md:mb-13 lg:mb-18">
          <SecondaryTabNav
            ariaLabel="Roadmap sections"
            mobileLabel="Roadmap section"
            items={[
              { label: 'Releases', href: '/roadmap', exact: true },
              { label: 'Shipped', href: '/roadmap#shipped' },
              { label: 'Backlog', href: '/backlog' },
            ]}
          />
        </div>
        <RoadmapGrid roadmaps={roadmaps} />
        <RoadmapViewFilter />
        <RoadmapEmptyModal />
      </div>
    </div>

    <Footer />
  </section>
</Layout>
