---
// src/pages/roadmap/[slug].astro
export const prerender = false;

import '@styles/page-roadmap.css';
import {
  fetchGitHubRoadmaps,
  getRoadmapMonthKey,
  getRoadmapSlug,
  getRoadmapCoverImage,
} from '@libs/githubRoadmap';

import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import Footer from '@components/Footer.astro';
import RoadmapDetailContent from '@components/roadmap/RoadmapDetailContent.astro';

const { slug } = Astro.params as { slug: string };

const roadmaps = await fetchGitHubRoadmaps();

let roadmap = roadmaps.find((entry) => entry.slug === slug);

// Legacy URLs used YYYY-MM; redirect to the canonical slug when possible.
if (!roadmap && /^\d{4}-\d{2}$/.test(slug)) {
  const legacyMatch = roadmaps.find((entry) => getRoadmapMonthKey(entry.releaseDate) === slug);

  if (legacyMatch) {
    if (!getRoadmapCoverImage(legacyMatch.number)) {
      return Astro.redirect('/roadmap', 302);
    }

    const canonicalSlug = getRoadmapSlug(legacyMatch);
    if (canonicalSlug !== slug) {
      return Astro.redirect(`/roadmap/${canonicalSlug}`, 301);
    }
    roadmap = legacyMatch;
  }
}

if (!roadmap) {
  return Astro.redirect('/roadmap', 302);
}

if (!getRoadmapCoverImage(roadmap.number)) {
  return Astro.redirect('/roadmap', 302);
}

const releaseDate = new Date(roadmap.releaseDate);
const formattedDate = releaseDate.toLocaleString('en-US', { month: 'long', year: 'numeric' });

const pageTitle = `${roadmap.title} — ${formattedDate} Roadmap`;
const pageDescription = roadmap.summary ?? `Datum roadmap for ${formattedDate}.`;
---

<Layout title={pageTitle} description={pageDescription} bodyClass="page-roadmap">
  <section class="datum-container">
    <Hero class="light" hideContent={true} hideHero />

    <div class="section--block section--block--pad bg-glacier-mist-700">
      <div class="max-width">
        <RoadmapDetailContent roadmap={roadmap} />
      </div>
    </div>

    <Footer />
  </section>
</Layout>
