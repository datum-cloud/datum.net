---
export const prerender = false;

import '@v1/styles/page-roadmap.css';
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import Footer from '@components/Footer.astro';
import { validateAndRefreshSession } from '@libs/auth';

const mode = process.env.MODE || import.meta.env.MODE;

// only for production mode, to enforce authentication
if (mode == 'production' || mode == 'local') {
  // Check authentication - redirect to login if not authenticated
  const { session } = await validateAndRefreshSession(Astro.cookies);

  if (!session) {
    // Redirect to login with return URL
    return Astro.redirect(
      `/auth/login/?redirect_uri=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`
    );
  }
}

const title = 'Shop';
const description = 'Browse and purchase our products.';
const icon = 'list-restart';
---

<Layout title={title} description={description} bodyClass="page-roadmap">
  <section class="datum-container">
    <Hero class="light" iconName={icon} title={title} description={description} />

    <div class="section--block section--block--pad bg-midnight-fjord dark">
      <div class="sr-element sr-products" data-embed="multiple_products">
        <script type="application/json" data-config="embed" is:inline>
          {
            "publishable_key": "sr_live_pk_e3d2346a89337978de277ee7686dcbe42c70",
            "options": {
              "products_to_display": "all",
              "categories": [],
              "products": [],
