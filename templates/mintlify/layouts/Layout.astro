---
import { ClientRouter } from 'astro:transitions';
import docsConfig from '@knowledge/docs.json';
import { AssistantSheet, AssistantProvider } from '../components/Assistant';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const mode = process.env.NODE_ENV || process.env.MODE || import.meta.env.MODE;
const isProduction = mode === 'production';
const integrations = docsConfig.integrations;
const { title = 'Mintlify Docs', description } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <meta name="msapplication-TileColor" content={docsConfig.colors.primary ?? '#ffffff'} />
    <meta name="charset" content="utf-8" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500;1,600;1,700;1,800&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* Analytics (Fathom) - Load early but defer execution */}
    {
      isProduction && integrations.fathom.siteId && (
        <>
          <link rel="preconnect" href="https://cdn.usefathom.com" crossorigin="anonymous" />
          <script
            src="https://cdn.usefathom.com/script.js"
            data-site={integrations.fathom.siteId}
            defer
            is:inline
          />
        </>
      )
    }
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <ClientRouter />
  </head>
  <body>
    <AssistantProvider client:only="react" />
    <div class="flex antialiased">
      <div class="mx-auto w-full max-w-350 min-w-0 flex-1">
        <slot />
      </div>
      <AssistantSheet client:only="react" transition:persist />
    </div>

    {/* Fathom event tracking - fires on any element with data-fathom-event */}
    <script is:inline define:vars={{ fathomEnabled: !!integrations.fathom.siteId && isProduction }}>
      if (fathomEnabled) {
        document.addEventListener('click', function (e) {
          var el = e.target.closest('[data-fathom-event]');
          if (el && window.fathom) {
            window.fathom.trackEvent(el.getAttribute('data-fathom-event'));
          }
        });
      }
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    overscroll-behavior-y: none;
  }

  ::view-transition-old(*),
  ::view-transition-new(*),
  ::view-transition-group(*) {
    animation-duration: 0s !important;
  }
</style>
