{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["node_modules", "dist", "tests/**/*", "playwright.config.ts"],
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["./src/components/*"],
      "@utils/*": ["./src/utils/*"],
      "@libs/*": ["./src/libs/*"],
      "@plugins/*": ["./src/plugins/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@v1/*": ["./src/v1/*"],
      "@content/*": ["./src/content/*"],
      "@hosts/*": ["./src/content/events/images/hosts/*"],
      "@guests/*": ["./src/content/events/images/guests/*"],
      "@data/*": ["./src/data/*"],
      "@styles/*": ["./src/v1/styles/*"],
      "@assets/*": ["./src/v1/assets/*"]
    },
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ]
  }
}
